{
  "extraKnownMarketplaces": {
    "my-skills": {
      "source": {
        "source": "github",
        "repo": "hico-mrmgn/Skills"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'echo \"$CLAUDE_TOOL_INPUT\" | python3 -c \"\nimport sys, json\ncmd = json.load(sys.stdin).get(\\\"command\\\", \\\"\\\")\ndangerous = [\\\"rm -rf /\\\", \\\"git push --force\\\", \\\"DROP TABLE\\\"]\nfor d in dangerous:\n    if d.lower() in cmd.lower():\n        print(f\\\"BLOCKED: {d}\\\")\n        sys.exit(2)\n\"'"
          }
        ]
      }
    ]
  }
}
